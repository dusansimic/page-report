# Two domains, one backend. pr-server routes by Host header:
# the app domain serves the homepage + ConnectRPC API, the pages
# domain serves login-gated report pages at /p/{id}.
# Caddy provisions TLS automatically; it also sets X-Forwarded-*
# headers on reverse_proxy by default — no extra header config needed.

{$APP_DOMAIN} {
	reverse_proxy app:8080
}

{$PAGES_DOMAIN} {
	reverse_proxy app:8080
}

# --- Local dev variant ---------------------------------------------
# Replace the blocks above with these (Caddy issues self-signed certs
# for *.localhost automatically; trust the local CA or click through):
#
# app.localhost {
# 	reverse_proxy app:8080
# }
#
# pages.localhost {
# 	reverse_proxy app:8080
# }
